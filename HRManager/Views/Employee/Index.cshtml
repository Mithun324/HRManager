@model IEnumerable<HRManager.Models.Employee>

@{
    ViewData["Title"] = "Employee Directory";
}

<div class="page-header">
    <h1>Employee Directory</h1>
    <a href="@Url.Action("Create")" class="btn btn-primary">+ Add New Employee</a>
</div>

<div class="search-wrapper">
    <form method="get" action="@Url.Action("Index")" class="search-form">
        <input type="text" name="searchString" class="form-control" placeholder="Search Name or Code..." value="@Context.Request.Query["searchString"]" />
        <button type="submit" class="btn btn-secondary">Search</button>
    </form>
</div>

<div class="table-responsive">
    <table class="custom-table" style="width: 100%; table-layout: fixed;">
        <thead>
            <tr>
                <th style="width: 15%;">Code</th>
                <th style="width: 25%;">Full Name</th>
                <th style="width: 25%;">Department</th>
                <th style="width: 15%;">Status</th>
                <th style="width: 20%; text-align: center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model) 
                {
                    <tr>
                        <td style="font-weight: 600; color: var(--primary);">@item.EmployeeCode</td>
                        <td style="font-weight: 500;">@item.FullName</td>
                        <td style="color: var(--text-muted);">@(item.EmploymentDetails?.Department ?? "N/A")</td>
                        <td>
                            @{
                                var status = item.EmploymentDetails?.ActivityStatus ?? "N/A";
                                var badgeBg = status.ToLower() == "active" ? "#e0f2fe" : "#f1f5f9";
                                var badgeColor = status.ToLower() == "active" ? "var(--accent)" : "var(--text-muted)";
                            }
                            <span style="padding: 0.25rem 0.625rem; font-size: 0.75rem; font-weight: 700; border-radius: 4px; background: @badgeBg; color: @badgeColor; display: inline-block;">
                                @status
                            </span>
                        </td>
                        <td style="text-align: center;">
                            <div class="action-links" style="justify-content: center; gap: 0.5rem;">
                                <a href="@Url.Action("Details", new { id = item.EmployeeId })" class="btn btn-secondary" style="padding: 0.375rem 0.75rem; font-size: 0.75rem;">View</a>
                                <a href="@Url.Action("Edit", new { id = item.EmployeeId })" class="btn btn-primary" style="padding: 0.375rem 0.75rem; font-size: 0.75rem;">Edit</a>
                                <a href="@Url.Action("Delete", new { id = item.EmployeeId })" class="btn btn-danger" style="padding: 0.375rem 0.75rem; font-size: 0.75rem;">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" style="text-align: center; padding: 4rem 2rem; color: var(--text-muted); font-size: 0.95rem;">
                        📁 No employee records found. Click <strong>+ Add New Employee</strong> to register your first team member.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>