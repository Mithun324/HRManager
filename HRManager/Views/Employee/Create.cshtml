@model HRManager.Models.Employee
@{ ViewBag.Title = "Add Employee"; }

<div class="card">
    <h2>Add New Employee</h2>
    @using (Html.BeginForm()) 
    {
        @Html.AntiForgeryToken()
        
        <div class="form-section">
            <h3>1. Personal Information</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label>Employee Code*</label>
                    @Html.TextBoxFor(m => m.EmployeeCode, new { @class = "form-control", required="required" })
                </div>
                <div class="form-group">
                    <label>Full Name*</label>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", required="required" })
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    @Html.TextBoxFor(m => m.EmailAddress, new { @class = "form-control", type="email" })
                </div>
                <div class="form-group">
                    <label>Mobile Number</label>
                    @Html.TextBoxFor(m => m.MobileNumber, new { @class = "form-control" })
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3>2. Parent Information</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label>Father's Name</label>
                    @Html.TextBoxFor(m => m.ParentInformation.FathersName, new { @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>Mother's Name</label>
                    @Html.TextBoxFor(m => m.ParentInformation.MothersName, new { @class = "form-control" })
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3>3. Employment Details</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label>Department</label>
                    @Html.TextBoxFor(m => m.EmploymentDetails.Department, new { @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>Status</label>
                    @Html.DropDownListFor(m => m.EmploymentDetails.ActivityStatus, new SelectList(new[] {"Active", "Inactive", "On Leave", "Suspended"}), new { @class = "form-control" })
                </div>
            </div>
        </div>
        

        <div style="margin-top: 20px;">
            <button type="submit" class="btn btn-success">Save Employee</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
        </div>
    }
</div>