@model HRManager.Models.Employee
@{ ViewBag.Title = "Edit Employee"; }

<div class="card">
    <h2>Edit Employee: @Model.FullName</h2>
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.EmployeeId)
        @Html.HiddenFor(m => m.CreatedDate)

        <!-- Replicate the sections from Create.cshtml here. -->
        <!-- Because properties are bound to the model, they will automatically populate -->
        
        <div class="form-section">
            <h3>Personal Information</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label>Employee Code*</label>
                    @Html.TextBoxFor(m => m.EmployeeCode, new { @class = "form-control", required="required" })
                </div>
                <div class="form-group">
                    <label>Full Name*</label>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", required="required" })
                </div>
            </div>
        </div>
        
        <!-- Parent, Employment, Social, Address sections map here -->
        
        <div style="margin-top: 20px;">
            <button type="submit" class="btn btn-primary">Update Changes</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
        </div>
    }
</div>